# Copy to .env (gitignored). Never commit real tokens.
# Used as: export TF_TOKEN_app_terraform_io="$TERRAFORM_TOKEN"
TERRAFORM_TOKEN=
# Tailscale admin API key — also in config/secrets/tailscale.enc.yaml (SOPS)
TAILSCALE_TOKEN=
# Provider reads TAILSCALE_API_KEY; set when sourcing: export TAILSCALE_API_KEY="${TAILSCALE_TOKEN}"
CLOUDFLARE_TOKEN=
# Provider reads CLOUDFLARE_API_TOKEN; set when sourcing: export CLOUDFLARE_API_TOKEN="${CLOUDFLARE_TOKEN}"
