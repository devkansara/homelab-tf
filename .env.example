# Copy to .env (gitignored). Never commit real tokens.
# Used as: set -a && source .env && set +a

TERRAFORM_TOKEN=
TAILSCALE_TOKEN=
CLOUDFLARE_TOKEN=

# Provider env aliases (set when sourcing)
# export TF_TOKEN_app_terraform_io="$TERRAFORM_TOKEN"
# export TAILSCALE_API_KEY="${TAILSCALE_TOKEN}"
# export CLOUDFLARE_API_TOKEN="${CLOUDFLARE_TOKEN}"

# Auth0 Management API M2M (terraform provider reads these directly)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Flip Auth0 module on (or set enable_auth0 = true in terraform.tfvars)
TF_VAR_enable_auth0=true

# Lab Monitor compose (on LXC 240 or local `docker compose` from apps/lab-monitor)
# API verifies ops JWTs; web build bakes VITE_* at image build time.
# SPA is a public client — no VITE client secret.
AUTH0_AUDIENCE=https://lab.devkansara.me/api
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://lab.devkansara.me/api
# VITE_AUTH0_CLIENT_ID = terraform output lab_monitor.spa_client_id after apply
