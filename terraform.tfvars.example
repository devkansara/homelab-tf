proxmox_endpoint  = "https://10.10.0.173:8006/"
proxmox_api_token = "terraform@pve!tf=REPLACE_WITH_TOKEN_UUID"
proxmox_insecure  = true
proxmox_node      = "node1"

# Contents of ~/.ssh/lab_discovery (or another key authorized on node1 as root)
proxmox_ssh_private_key = <<-EOT
-----BEGIN OPENSSH PRIVATE KEY-----
...
-----END OPENSSH PRIVATE KEY-----
EOT

# Lab monitor (set true after LXC OS + compose bootstrap)
# enable_lab_monitor_docker = true

# Auth0: set AUTH0_* in .env + TF_VAR_enable_auth0=true, then apply
# enable_auth0 = true

# Immich Kiosk — lab LAN :3456, not on Cloudflare tunnel.
# Create a dedicated Immich user + scoped API key first; then:
# immich_kiosk_api_key = "..."   # sensitive — also in SOPS immich.enc.yaml as KIOSK_API_KEY
# immich_kiosk_album_id = "c60e66de-4527-452a-a642-063543527df1"
